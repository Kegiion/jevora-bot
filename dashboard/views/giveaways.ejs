<div class="max-w-4xl mx-auto">
  <h2 class="text-3xl font-bold neon-purple mb-8">Aktive Giveaways</h2>

  <div class="glass neon rounded-xl p-6">
    <p class="text-gray-400 mb-4">Giveaways werden über den Discord-Befehl <code class="bg-gray-800 px-2 py-1 rounded">/giveaway</code> gestartet.</p>
    <table class="w-full">
      <thead>
        <tr class="border-b border-white/10">
          <th class="text-left py-3">Preis</th>
          <th class="text-left py-3">Winners</th>
          <th class="text-left py-3">Endet</th>
        </tr>
      </thead>
      <tbody id="giveaways-body"></tbody>
    </table>
  </div>
</div>
<script>
fetch('/api/giveaways/<%= guildId %>')
  .then(r => r.json())
  .then(giveaways => {
    const tbody = document.getElementById('giveaways-body');
    giveaways.forEach(g => {
      const tr = document.createElement('tr');
      tr.className = 'border-b border-white/5';
      const end = new Date(g.end_time);
      tr.innerHTML = '<td class="py-3 font-semibold">' + g.prize + '</td><td class="py-3">' + g.winners + '</td><td class="py-3">' + end.toLocaleString() + '</td>';
      tbody.appendChild(tr);
    });
    if (giveaways.length === 0) {
      tbody.innerHTML = '<tr><td colspan="3" class="py-4 text-center text-gray-400">Keine aktiven Giveaways</td></tr>';
    }
  });
</script>