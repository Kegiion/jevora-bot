<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Jevora Dashboard</title>
  <style>
    * { box-sizing: border-box; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 50%, #0f172a 100%);
      min-height: 100vh; color: white;
    }
    .glass { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); }
    .neon-purple { color: #a855f7; }
    .btn-primary { background: linear-gradient(135deg, #8b5cf6 0%, #3b82f6 100%); }
    .btn-primary:hover { filter: brightness(1.1); }
    .card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 12px; }
  </style>
</head>
<body>
  <nav class="glass flex justify-between items-center p-4 sticky top-0">
    <div class="flex items-center space-x-3">
      <div class="w-10 h-10 rounded-full bg-gradient-to-r from-purple-500 to-blue-500 flex items-center justify-center font-bold text-xl">J</div>
      <h1 class="text-2xl font-bold">
        <span class="neon-purple">J</span><span class="text-blue-400">evora</span>
      </h1>
    </div>
    <% if (user) { %>
      <div class="flex items-center gap-4">
        <span class="text-gray-300">Hi, <%= user.username %></span>
        <form action="/auth/logout" method="POST">
          <button class="btn-primary px-4 py-2 rounded-lg text-white font-medium">Logout</button>
        </form>
      </div>
    <% } %>
  </nav>
  <main class="max-w-6xl mx-auto p-6"><%- body %></main>
</body>
</html>