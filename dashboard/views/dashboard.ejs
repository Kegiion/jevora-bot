<h2 style="font-size:1.75rem; font-weight:bold; color:#a855f7; margin-bottom:32px;">Server auswählen</h2>
<div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(250px, 1fr)); gap:24px;">
  <% user.guilds.forEach(guild => { %>
    <a href="/dashboard/<%= guild.id %>" class="glass card" style="padding:24px; text-decoration:none; color:inherit; transition:transform 0.2s;">
      <% if (guild.icon) { %>
        <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" style="width:48px; height:48px; border-radius:50%; margin-bottom:16px;">
      <% } else { %>
        <div class="card" style="width:48px; height:48px; border-radius:50%; display:flex; align-items:center; justify-content:center; font-weight:bold; margin-bottom:16px;"><%= guild.name.charAt(0) %></div>
      <% } %>
      <h3 style="font-size:1.25rem; font-weight:600;"><%= guild.name %></h3>
    </a>
  <% }) %>
</div>