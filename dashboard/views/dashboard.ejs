<h2 style="font-size:28px; font-weight:bold; color:#a855f7; margin-bottom:32px;">Server auswählen</h2>
<div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(240px, 1fr)); gap:20px;">
  <% user.guilds.forEach(guild => { %>
    <a href="/dashboard/<%= guild.id %>" class="card" style="text-decoration:none; color:inherit; display:block; transition:all 0.2s;">
      <% if (guild.icon) { %>
        <img src="https://cdn.discordapp.com/icons/<%= guild.id %>/<%= guild.icon %>.png" style="width:40px; height:40px; border-radius:50%; margin-bottom:12px;">
      <% } else { %>
        <div style="width:40px; height:40px; border-radius:50%; background:linear-gradient(135deg, #a855f7, #3b82f6); display:flex; align-items:center; justify-content:center; font-weight:bold; margin-bottom:12px;"><%= guild.name.charAt(0) %></div>
      <% } %>
      <h3 style="font-size:18px; font-weight:600; margin:0;"><%= guild.name %></h3>
    </a>
  <% }) %>
</div>